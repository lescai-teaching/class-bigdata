
// base defaults
params {
	publish_dir_mode = 'copy'
	outdir           = "."
	input            = "https://raw.githubusercontent.com/lescai-teaching/class-bigdata/refs/heads/main/L31_nextflow_more-coding/data/input.tsv"
	max_cpus         = 1
	max_memory       = 4.GB
}

// profiles parameters
profiles {
	helicon {
        apptainer.enabled    = true
        apptainer.autoMounts = true
		params {
            max_cpus   = 4
			max_memory = 16.GB
		}
		process {
			executor = 'slurm'
			queue    = 'short'
			withName: MEAN_SD {
				memory = 5.GB
				time   = 5.m
				cpus = 1
			}
			withName: PC1_LOADING {
				memory = 10.GB
				time   = 15.m
				cpus   = 1
			}
			withName: MAD {
				memory = 5.GB
				time   = 10.m
				cpus   = 1
			}
			withName: SUMMARY {
				memory = 5.GB
				time   = 10.m
				cpus   = 1
		    }
	    }
	}
	desktop {
        docker.enabled         = true
        docker.userEmulation   = true
		process.executor = 'local'
		params {
			max_cpus   = 1
			max_memory = 4.GB
		}
	}
	arm {
        docker.runOptions      = '-u $(id -u):$(id -g) --platform=linux/amd64'
    }
}
